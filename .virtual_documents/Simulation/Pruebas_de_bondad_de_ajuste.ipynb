


from scipy.stats import poisson, chisquare, kstest, gamma, norm , lognorm, t
import pandas as pd 
import matplotlib.pyplot as plt
from random_numbers import GLC, Poisson
import numpy as np





def chisquare_poisson(data):
    # Estimar lambda

    lam_hat = np.mean(data)
    n = len(data)

    # Máximo observado

    m = np.max(data)

    # Frecuencias observadas
    # categorías: 0,...,m-1, >= m

    observed = np.array([
        np.sum(data == k) for k in range(m)
    ] + [
        np.sum(data >= m)
    ])

    # Frecuencias esperadas
    expected = np.array([
        poisson.pmf(k, lam_hat) * n for k in range(m)
    ] + [
        (1 - poisson.cdf(m - 1, lam_hat)) * n
    ])

    # Prueba chi-cuadrada
    chi2_stat, p_value = chisquare(observed, expected)
    print("Lambda estimado:", lam_hat)
    print("Chi-cuadrada:", chi2_stat)
    print("p-value:", p_value)


size = 100000

# Genera Poisson
poi = Poisson(10)
data = np.array(poi.sample(size))

chisquare_poisson(data)





data = pd.read_csv("data/Alpha.txt",sep="\t")


values = data["N "].values   # valores de la variable
observed = data["Freq"].values             # frecuencias observadas

n = observed.sum()

# Lambda estimado (media ponderada)
lam_hat = np.sum(values * observed) / n

# ---- Probabilidades esperadas ----
max_val = values.max()

# Probabilidades hasta max_val - 1
expected_probs = poisson.pmf(values[:-1], lam_hat)

# Última categoría: >= max_val
p_tail = 1 - poisson.cdf(max_val - 1, lam_hat)

expected_probs = np.append(expected_probs, p_tail)

# Frecuencias esperadas
expected = expected_probs * n

# ---- Prueba chi-cuadrada ----
chi2_stat, p_value = chisquare(observed, expected)

print("Lambda estimado:", lam_hat)
print("Chi-cuadrada:", chi2_stat)
print("p-value:", p_value)





